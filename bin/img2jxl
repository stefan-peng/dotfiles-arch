#!/bin/bash

set -u

command=magick

. /Users/speng/.bashrc

# Ensure conversion command is installed
if ! command -v "$command" > /dev/null 2>&1; then
    echo "$command is not installed. Please install it first."
    exit 1
fi

# Check for input file
if [ $# -ne 1 ]; then
    echo "Usage: $0 <input_file>"
    exit 1
fi

input_file="$1"

# Ensure the input file exists
if [ ! -f "$input_file" ]; then
    echo "File '$input_file' does not exist."
    exit 1
fi

# Define the output file name (same name, but with .jxl extension)
output_file="${input_file%.*}.jxl"

# Convert the input file to JPEG-XL using cjxl
# cjxl --lossless_jpeg=1 "$input_file" "$output_file"
if ! "$command" "$input_file" "$output_file"; then
    echo "Conversion failed; leaving original in place." >&2
    exit 1
fi

# Move input file to ~/.Trash
if [ -f "$output_file" ]; then
    mv "$input_file" "$HOME/.Trash/"
else
    echo "Conversion did not create '$output_file'; leaving original in place." >&2
    exit 1
fi

echo "Conversion complete."
exit 0
