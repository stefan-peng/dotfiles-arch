#
# ~/.bashrc
#

# If not running interactively, don't do anything
# [[ $- != *i* ]] && return

export PATH=~/bin:~/.local/bin:$PATH:/opt/homebrew/bin:/usr/local/go/bin:/Users/speng/Library/Python/3.9/bin

if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

#if ! pgrep -u "$USER" ssh-agent > /dev/null; then
    #ssh-agent -t 1h > "$XDG_RUNTIME_DIR/ssh-agent.env"
#fi
#if [[ ! "$SSH_AUTH_SOCK" ]]; then
    #source "$XDG_RUNTIME_DIR/ssh-agent.env" >/dev/null
#fi

#PS1='\$ '
PS1="$(prompt-macos) \$ "

export EDITOR=hx
export LANG=en_US.UTF-8

alias ed='ed -p "% "'
alias diff='diff --color=auto'
alias grep='grep --color=auto'
alias ip='ip -color=auto'
alias n='newsboat -u $HOME/.newsboat/urls -c $HOME/.newsboat/cache.db'
alias y='newsboat -u $HOME/.newsboat/youtube-urls -c $HOME/.newsboat/youtube-cache.db'
alias glances='glances --disable-bg'
alias ss='mpv --profile=skipsilence'
alias wtr='curl wttr.in'
#alias cat='bat'
#alias ls='lsd'
alias ll='ls -l'
alias la='ls -a'
alias unzip='atool --extract --explain'

[ -r /usr/share/bash-completion/bash_completion ] && . /usr/share/bash-completion/bash_completion

. "$HOME/.cargo/env"

# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/speng/.lmstudio/bin"
# End of LM Studio CLI section


. "$HOME/.atuin/bin/env"

[[ -f ~/.bash-preexec.sh ]] && source ~/.bash-preexec.sh
eval "$(atuin init bash)"
